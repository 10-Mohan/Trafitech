# -----------------------------------------------------------------------------
# TRAFFITECH PRODUCTION ENVIRONMENT TEMPLATE
# Instructions: Copy this file to .env and fill in your cloud credentials.
# -----------------------------------------------------------------------------

# [SERVER] - Keep these secret!
PORT=5000
JWT_SECRET=your_super_secret_jwt_key_here
NODE_ENV=production

# [DATABASE] - Get this from MongoDB Atlas (cloud.mongodb.com)
# Example: mongodb+srv://<user>:<password>@cluster0.abcde.mongodb.net/traffitech
MONGODB_URI=

# [PAYMENTS] - Get these from Stripe Dashboard (stripe.com)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# [FRONTEND] - These are used by the React app (if using Vite)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_API_URL=https://your-backend-url.onrender.com/api
